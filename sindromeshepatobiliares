<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Síndromes Hepatobiliares — Kyra Barreneche</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,500&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#180810;--surf:#231020;--surf2:#2e142a;--surf3:#3a1a34;
  --pk:#c0507a;--pk2:#d97aaa;--pk3:#edaace;--pk4:#fce8f2;
  --gold:#e8c07a;--teal:#6dcfb8;--red:#d95560;
  --tx:#fdf0f6;--tx2:#d4a0be;--tx3:#a07090;
  --bdr:rgba(217,122,170,.15);--bdrS:rgba(217,122,170,.30);
  --r:12px;--rs:8px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--tx);font-family:'IBM Plex Sans',sans-serif;font-size:15px;line-height:1.75}
/* PROGRESS */
#pb{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--pk),var(--pk3),var(--gold));z-index:9999;width:0%;transition:width .1s linear}
/* NAV */
nav{position:fixed;top:0;left:0;right:0;height:52px;background:rgba(24,8,16,.96);backdrop-filter:blur(14px);border-bottom:1px solid var(--bdr);z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:0 1.4rem}
.nbrand{font-family:'Playfair Display',serif;font-size:.9rem;font-weight:700;color:var(--pk3);letter-spacing:.03em}
.nlinks{display:flex;gap:0;list-style:none}
.nlinks a{color:var(--tx3);text-decoration:none;font-size:.63rem;font-weight:500;letter-spacing:.05em;text-transform:uppercase;padding:.28rem .5rem;border-radius:6px;transition:all .2s}
.nlinks a:hover{color:var(--pk3);background:rgba(217,122,170,.1)}
/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:6rem 2rem 4rem;background:radial-gradient(ellipse at 30% 25%,rgba(192,80,122,.10) 0%,transparent 60%),radial-gradient(ellipse at 70% 75%,rgba(232,192,122,.06) 0%,transparent 60%);position:relative;overflow:hidden}
.eyebrow{font-family:'IBM Plex Mono',monospace;font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;color:var(--pk2);margin-bottom:.9rem}
.htitle{font-family:'Playfair Display',serif;font-size:clamp(2.4rem,7vw,4.6rem);font-weight:900;line-height:1.05;margin-bottom:.5rem}
.htitle em{color:var(--pk2);font-style:italic}
.hsub{font-size:.88rem;color:var(--tx2);max-width:520px;margin:0 auto 1.8rem;line-height:1.65}
.author-pill{display:inline-flex;align-items:center;gap:.8rem;background:linear-gradient(135deg,rgba(192,80,122,.14),rgba(232,192,122,.07));border:1px solid var(--bdrS);border-radius:100px;padding:.55rem 1.4rem;margin-bottom:.9rem}
.ava{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--pk),var(--pk3));display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-weight:700;font-size:.88rem;color:#fff;flex-shrink:0}
.ainfo{text-align:left}
.albl{font-family:'IBM Plex Mono',monospace;font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:var(--tx3);display:block}
.aname{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--pk3)}
.hmeta{font-family:'IBM Plex Mono',monospace;font-size:.64rem;color:var(--tx3);letter-spacing:.07em}
.scue{position:absolute;bottom:2.2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.45rem;color:var(--tx3);font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;animation:fl 3s ease-in-out infinite}
.sline{width:1px;height:34px;background:linear-gradient(to bottom,var(--pk2),transparent)}
@keyframes fl{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(-7px)}}
/* CASCADE MAP */
.thesis{background:linear-gradient(135deg,var(--surf2),var(--surf3));border:1px solid var(--bdrS);border-left:4px solid var(--pk2);border-radius:var(--r);padding:1.5rem 2rem;margin:0 auto 2.5rem;max-width:780px;text-align:center}
.thesis p{font-family:'Playfair Display',serif;font-size:1rem;font-style:italic;color:var(--pk3);line-height:1.7;margin:0}
.thesis span{font-family:'IBM Plex Sans',sans-serif;font-style:normal;font-size:.76rem;color:var(--tx3);display:block;margin-top:.45rem}
/* FLOW */
.flow-chain{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin:1.5rem 0;justify-content:center}
.flow-node{background:var(--surf2);border:1px solid var(--bdrS);border-radius:var(--rs);padding:.55rem 1rem;font-size:.8rem;font-weight:600;color:var(--pk3);white-space:nowrap}
.flow-node.active{background:rgba(192,80,122,.18);border-color:var(--pk)}
.flow-arrow{color:var(--pk2);font-size:1.1rem;flex-shrink:0}
/* MAIN */
main{max-width:940px;margin:0 auto;padding:4rem 2rem 6rem}
section{margin-bottom:5rem;scroll-margin-top:70px}
.sh{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;padding-bottom:.8rem;border-bottom:1px solid var(--bdr)}
.snum{font-family:'IBM Plex Mono',monospace;font-size:.58rem;color:var(--pk2);letter-spacing:.15em;background:rgba(217,122,170,.1);padding:.25rem .6rem;border-radius:100px;border:1px solid var(--bdr);white-space:nowrap}
.stitle{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;color:var(--tx);line-height:1.2}
.stitle em{color:var(--pk2);font-style:italic}
p{color:var(--tx2);margin-bottom:1rem;line-height:1.8}
p strong{color:var(--tx);font-weight:600}
/* CARD */
.card{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:1.35rem 1.55rem;margin-bottom:1.1rem;transition:border-color .2s,box-shadow .2s}
.card:hover{border-color:var(--bdrS);box-shadow:0 2px 18px rgba(192,80,122,.07)}
.ctitle{font-size:.72rem;font-weight:600;letter-spacing:.09em;text-transform:uppercase;color:var(--pk3);margin-bottom:.85rem;display:flex;align-items:center;gap:.5rem}
.ctitle::before{content:'';display:inline-block;width:16px;height:2px;background:var(--pk2);border-radius:2px;flex-shrink:0}
/* CALLOUTS */
.cl{border-radius:var(--r);padding:1.05rem 1.25rem;margin:1.25rem 0;border-left:3px solid}
.cl-f{background:rgba(192,80,122,.07);border-color:var(--pk)}
.cl-a{background:rgba(232,192,122,.07);border-color:var(--gold)}
.cl-p{background:rgba(109,207,184,.07);border-color:var(--teal)}
.cl-d{background:rgba(217,85,96,.08);border-color:var(--red)}
.clbl{font-family:'IBM Plex Mono',monospace;font-size:.6rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;margin-bottom:.45rem;display:flex;align-items:center;gap:.38rem}
.cl-f .clbl{color:var(--pk2)}.cl-a .clbl{color:var(--gold)}.cl-p .clbl{color:var(--teal)}.cl-d .clbl{color:var(--red)}
.cl p{font-size:.87rem;margin:0}
/* ACCORDION */
.acc{border:1px solid var(--bdr);border-radius:var(--r);overflow:hidden;margin-bottom:.65rem}
.acc-h{display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.15rem;cursor:pointer;background:var(--surf);transition:background .2s;user-select:none}
.acc-h:hover{background:var(--surf2)}
.acc-t{font-weight:600;color:var(--tx);font-size:.88rem;display:flex;align-items:center;gap:.5rem}
.acc-i{font-size:.66rem;color:var(--pk2);transition:transform .3s;font-family:'IBM Plex Mono',monospace}
.acc.open .acc-i{transform:rotate(180deg)}
.acc-b{display:none;padding:.95rem 1.15rem;background:var(--surf);border-top:1px solid var(--bdr)}
.acc.open .acc-b{display:block}
.acc-b p{font-size:.86rem;margin-bottom:.5rem}.acc-b p:last-child{margin:0}
/* GRID */
.g2{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;margin:1.1rem 0}
.g3{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.85rem;margin:1.1rem 0}
/* CASCADE */
.casc{display:flex;flex-direction:column;position:relative;padding-left:2.1rem;margin:1.3rem 0}
.casc::before{content:'';position:absolute;left:8px;top:10px;bottom:10px;width:2px;background:linear-gradient(to bottom,var(--pk),rgba(217,122,170,.1));border-radius:2px}
.ci{position:relative;padding:.75rem 0 .75rem .95rem;border-bottom:1px solid var(--bdr)}
.ci:last-child{border-bottom:none}
.ci::before{content:'';position:absolute;left:-1.78rem;top:1.02rem;width:10px;height:10px;border-radius:50%;border:2px solid var(--pk2);background:var(--bg)}
.cst{font-family:'IBM Plex Mono',monospace;font-size:.58rem;color:var(--pk2);letter-spacing:.12em;margin-bottom:.18rem}
.cn{font-weight:600;color:var(--tx);font-size:.91rem;margin-bottom:.2rem}
.cd{font-size:.83rem;color:var(--tx2);line-height:1.6}
/* TABLE */
.tbl{width:100%;border-collapse:collapse;margin:1.1rem 0;font-size:.85rem;display:block;overflow-x:auto}
.tbl thead tr{background:var(--surf2);border-bottom:2px solid var(--bdrS)}
.tbl th{padding:.7rem .95rem;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:var(--pk3);font-weight:500;white-space:nowrap}
.tbl td{padding:.65rem .95rem;border-bottom:1px solid var(--bdr);color:var(--tx2);vertical-align:top}
.tbl tr:last-child td{border-bottom:none}
.tbl tr:hover td{background:rgba(217,122,170,.03)}
.tdl{font-weight:600;color:var(--pk3);white-space:nowrap}
/* DIVIDER */
hr.d{border:none;border-top:1px solid var(--bdr);margin:2.8rem 0}
/* TAGS */
.tag{display:inline-block;background:rgba(217,122,170,.1);border:1px solid var(--bdr);border-radius:100px;padding:.16rem .58rem;font-family:'IBM Plex Mono',monospace;font-size:.6rem;color:var(--pk3);font-weight:500;letter-spacing:.06em;text-transform:uppercase;margin-right:.28rem;margin-bottom:.28rem}
ul,ol{padding-left:1.35rem;color:var(--tx2)}
li{margin-bottom:.38rem;font-size:.89rem;line-height:1.7}
li strong{color:var(--tx)}

/* ===== SYNDROME COLOR CODING ===== */
.s-cole{--sc:#e8b06a;--scl:rgba(232,176,106,.12)}
.s-cole .sh{border-color:rgba(232,176,106,.25)}
.s-cole .stitle em,.s-cole .snum{color:var(--sc)}
.s-cole .snum{background:rgba(232,176,106,.1);border-color:rgba(232,176,106,.2)}
.s-cole .ctitle::before{background:var(--sc)}
.s-cole .ctitle{color:var(--sc)}
.s-cole .casc::before{background:linear-gradient(to bottom,var(--sc),rgba(232,176,106,.1))}
.s-cole .ci::before{border-color:var(--sc)}

.s-cole2{--sc:#d97aaa;--scl:rgba(217,122,170,.12)}
.s-cole2 .sh{border-color:rgba(217,122,170,.25)}
.s-cole2 .stitle em,.s-cole2 .snum{color:var(--sc)}
.s-cole2 .snum{background:rgba(217,122,170,.1);border-color:rgba(217,122,170,.2)}
.s-cole2 .ctitle::before{background:var(--sc)}
.s-cole2 .ctitle{color:var(--sc)}

.s-cole3{--sc:#e87a7a;--scl:rgba(232,122,122,.12)}
.s-cole3 .sh{border-color:rgba(232,122,122,.25)}
.s-cole3 .stitle em,.s-cole3 .snum{color:var(--sc)}
.s-cole3 .snum{background:rgba(232,122,122,.1);border-color:rgba(232,122,122,.2)}
.s-cole3 .ctitle::before{background:var(--sc)}
.s-cole3 .ctitle{color:var(--sc)}

.s-pnc{--sc:#7ab8e8;--scl:rgba(122,184,232,.12)}
.s-pnc .sh{border-color:rgba(122,184,232,.25)}
.s-pnc .stitle em,.s-pnc .snum{color:var(--sc)}
.s-pnc .snum{background:rgba(122,184,232,.1);border-color:rgba(122,184,232,.2)}
.s-pnc .ctitle::before{background:var(--sc)}
.s-pnc .ctitle{color:var(--sc)}

.s-col{--sc:#7ae8b8;--scl:rgba(122,232,184,.12)}
.s-col .sh{border-color:rgba(122,232,184,.25)}
.s-col .stitle em,.s-col .snum{color:var(--sc)}
.s-col .snum{background:rgba(122,232,184,.1);border-color:rgba(122,232,184,.2)}
.s-col .ctitle::before{background:var(--sc)}
.s-col .ctitle{color:var(--sc)}

/* QUIZ */
#quiz-wrap{background:var(--surf);border:1px solid var(--bdr);border-radius:16px;padding:2rem;margin-top:2rem}
.qhdr{text-align:center;margin-bottom:2rem;padding-bottom:1.4rem;border-bottom:1px solid var(--bdr)}
.qbadge{display:inline-block;background:rgba(192,80,122,.12);border:1px solid var(--pk);border-radius:100px;padding:.26rem .82rem;font-family:'IBM Plex Mono',monospace;font-size:.6rem;color:var(--pk2);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.65rem}
.qtitle{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--tx);margin-bottom:.38rem}
.qdesc{font-size:.82rem;color:var(--tx3);max-width:480px;margin:0 auto;line-height:1.6}
/* Quiz nav tabs */
.qtabs{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2rem;justify-content:center}
.qtab{background:var(--surf2);border:1px solid var(--bdr);border-radius:var(--rs);padding:.4rem .9rem;font-family:'IBM Plex Mono',monospace;font-size:.65rem;color:var(--tx3);cursor:pointer;transition:all .2s;letter-spacing:.05em;text-transform:uppercase}
.qtab:hover,.qtab.active{color:var(--pk3);border-color:var(--bdrS);background:rgba(217,122,170,.1)}
.qblock{display:none}.qblock.show{display:block}
.qcard{background:var(--surf2);border:1px solid var(--bdr);border-radius:var(--r);padding:1.4rem;margin-bottom:1.2rem;transition:border-color .2s}
.qcard.answered{border-color:var(--bdrS)}
.qhd{display:flex;align-items:flex-start;gap:.85rem;margin-bottom:.9rem}
.qn{flex-shrink:0;width:28px;height:28px;border-radius:7px;background:rgba(217,122,170,.12);border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono',monospace;font-size:.72rem;font-weight:600;color:var(--pk2)}
.qstem{font-size:.88rem;color:var(--tx);line-height:1.7;font-weight:500}
.qcase{background:rgba(0,0,0,.22);border-left:2px solid var(--pk);border-radius:0 var(--rs) var(--rs) 0;padding:.7rem .9rem;margin-bottom:.85rem;font-size:.83rem;color:var(--tx2);line-height:1.72;font-style:italic}
.qqst{font-size:.87rem;font-weight:600;color:var(--tx);margin-bottom:.85rem}
.opts{display:flex;flex-direction:column;gap:.45rem;margin-bottom:.85rem}
.opt{display:flex;align-items:flex-start;gap:.7rem;padding:.65rem .9rem;border:1px solid var(--bdr);border-radius:var(--rs);cursor:pointer;background:var(--surf);transition:all .18s}
.opt:hover{border-color:var(--pk2);background:rgba(217,122,170,.05)}
.opt.sel{border-color:var(--pk2);background:rgba(217,122,170,.08)}
.opt.ok{border-color:#5ab87a;background:rgba(90,184,122,.08)}
.opt.ng{border-color:#d95560;background:rgba(217,85,96,.08)}
.ol{flex-shrink:0;width:21px;height:21px;border-radius:5px;background:var(--surf3);border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono',monospace;font-size:.63rem;font-weight:600;color:var(--tx3);transition:all .18s}
.opt.sel .ol{color:var(--pk3);border-color:var(--pk2)}
.opt.ok .ol{color:#5ab87a;border-color:#5ab87a;background:rgba(90,184,122,.15)}
.opt.ng .ol{color:#d95560;border-color:#d95560;background:rgba(217,85,96,.15)}
.otxt{font-size:.84rem;color:var(--tx2);line-height:1.58;padding-top:.04rem}
.cbtn{background:var(--pk);border:none;border-radius:var(--rs);padding:.52rem 1.2rem;color:#fff;font-family:'IBM Plex Sans',sans-serif;font-size:.79rem;font-weight:600;cursor:pointer;transition:all .2s;letter-spacing:.03em}
.cbtn:hover{background:var(--pk2);transform:translateY(-1px)}
.cbtn:disabled{background:var(--surf3);color:var(--tx3);cursor:not-allowed;transform:none}
.fb{display:none;margin-top:.85rem;padding:.9rem 1.05rem;border-radius:var(--rs);font-size:.83rem;line-height:1.7}
.fb.ok-fb{display:block;background:rgba(90,184,122,.08);border:1px solid rgba(90,184,122,.28);color:#a8e0ba}
.fb.ng-fb{display:block;background:rgba(217,85,96,.08);border:1px solid rgba(217,85,96,.28);color:#f0a8aa}
.fbl{font-weight:700;margin-bottom:.32rem;font-family:'IBM Plex Mono',monospace;font-size:.65rem;letter-spacing:.1em;text-transform:uppercase}
.ok-fb .fbl{color:#5ab87a}.ng-fb .fbl{color:#d95560}
/* section quiz scores */
.qscore{font-family:'IBM Plex Mono',monospace;font-size:.78rem;color:var(--tx3);margin-top:.8rem;text-align:right}
#total-panel{display:none;background:var(--surf2);border:1px solid var(--bdrS);border-radius:var(--r);padding:2rem;text-align:center;margin-top:1.8rem}
.tscore{font-family:'Playfair Display',serif;font-size:3.4rem;font-weight:900;color:var(--pk3);display:block;margin-bottom:.25rem}
.tslbl{color:var(--tx3);font-size:.82rem;margin-bottom:.85rem}
.tsmsg{font-size:.89rem;color:var(--tx2);max-width:420px;margin:0 auto 1.35rem;line-height:1.6}
.rbtn{background:transparent;border:1px solid var(--bdrS);border-radius:var(--rs);padding:.52rem 1.3rem;color:var(--pk3);font-family:'IBM Plex Sans',sans-serif;font-size:.79rem;cursor:pointer;transition:all .2s;font-weight:500}
.rbtn:hover{background:rgba(217,122,170,.1);border-color:var(--pk2)}
/* COMPARATIVE TABLE */
.comp-table{width:100%;border-collapse:collapse;font-size:.82rem;display:block;overflow-x:auto;margin:1.5rem 0}
.comp-table th{background:var(--surf2);padding:.75rem .9rem;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;border:1px solid var(--bdrS);white-space:nowrap}
.comp-table th:first-child{color:var(--tx3)}
.comp-table td{padding:.65rem .9rem;border:1px solid var(--bdr);vertical-align:top;color:var(--tx2);line-height:1.55}
.comp-table td:first-child{font-weight:700;color:var(--pk3);background:var(--surf2);white-space:nowrap}
.comp-table tr:hover td{background:rgba(217,122,170,.03)}
.comp-table .ok{color:#5ab87a;font-weight:600}.comp-table .ng{color:#d95560;font-weight:600}.comp-table .maybe{color:var(--gold);font-weight:600}
/* footer */
footer{border-top:1px solid var(--bdr);padding:2.4rem 2rem;text-align:center;color:var(--tx3);font-size:.74rem;max-width:940px;margin:0 auto}
.fn{font-family:'Playfair Display',serif;font-size:.93rem;font-weight:700;color:var(--pk3);display:block;margin-bottom:.28rem}
.fq{font-family:'IBM Plex Mono',monospace;font-style:italic;color:var(--pk);font-size:.68rem;display:block;margin-top:.45rem;letter-spacing:.04em}
@media(max-width:640px){.nlinks{display:none}main{padding:3rem 1.1rem 5rem}.g2,.g3{grid-template-columns:1fr}}
</style>
</head>
<body>
<div id="pb"></div>
<nav>
  <span class="nbrand">Síndromes Hepatobiliares</span>
  <ul class="nlinks">
    <li><a href="#s-cole">Colelitíase</a></li>
    <li><a href="#s-cole2">Colestase</a></li>
    <li><a href="#s-cole3">Colecistite</a></li>
    <li><a href="#s-pnc">Pancreatite</a></li>
    <li><a href="#s-col">Colangite</a></li>
    <li><a href="#comparativo">Comparativo</a></li>
    <li><a href="#simulado">Simulado</a></li>
  </ul>
</nav>

<div class="hero">
  <p class="eyebrow">Semiologia I · Síndromes Hepatobiliares · CENSUPEG 2026</p>
  <h1 class="htitle">Síndromes <em>Hepatobiliares</em></h1>
  <p class="hsub">Colelitíase · Colestase · Colecistite · Pancreatite · Colangite — em cascata fisiopatológica, do cálculo à sepse biliar.</p>
  <div class="author-pill">
    <div class="ava">K</div>
    <div class="ainfo">
      <span class="albl">Material elaborado por</span>
      <span class="aname">Kyra Barreneche</span>
    </div>
  </div>
  <p class="hmeta">Prof. Dr. João Vitor Galo Esteves · Faculdade CENSUPEG · Joinville / SC</p>
  <div class="scue"><span>role para explorar</span><div class="sline"></div></div>
</div>

<main>
<div class="thesis">
  <p>"O ponto da obstrução determina a síndrome. A síndrome determina o quadro clínico. O quadro clínico determina a semiologia."</p>
  <span>— Tese central da aula de Síndromes Hepatobiliares · Prof. Dr. João Vitor Galo Esteves</span>
</div>

<!-- FLOW CHAIN -->
<div class="flow-chain">
