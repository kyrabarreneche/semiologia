}

const state = { answers:{}, answered:{}, totCorrect:0, totAnswered:0 };
const sections = { cole:[1,2,3,4,5], cole2:[6,7,8,9,10], cole3:[11,12,13,14,15], pnc:[16,17,18,19,20], col:[21,22,23,24,25] };
const secScores = { cole:0, cole2:0, cole3:0, pnc:0, col:0 };
const secNames = { cole:'Colelitíase', cole2:'Colestase', cole3:'Colecistite', pnc:'Pancreatite', col:'Colangite' };

function getSec(q) {
